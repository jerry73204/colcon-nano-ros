#!/usr/bin/env bash
# .envrc for colcon-cargo-ros2 development
# Automatically sources ROS 2 environment when entering this directory
# Used by direnv (https://direnv.net/)

# Try to find and source ROS 2 setup
ROS_DISTRO_FOUND=""

# Check for specific distros in order of preference (newest first)
for distro in jazzy iron humble; do
    if [ -f "/opt/ros/${distro}/setup.bash" ]; then
        ROS_DISTRO_FOUND="${distro}"
        # shellcheck disable=SC1090
        source "/opt/ros/${distro}/setup.bash"
        echo "✅ Sourced ROS 2 ${distro} environment"
        break
    fi
done

# Show warning if no ROS installation found
if [ -z "$ROS_DISTRO_FOUND" ]; then
    echo "⚠️  Warning: No ROS 2 installation found in /opt/ros/"
    echo "   Expected one of: jazzy, iron, humble"
    echo "   "
    echo "   user-libs workspace (rclrs, rosidl-runtime-rs) requires ROS 2 to build."
    echo "   build-tools workspace can be built without ROS 2."
    echo "   "
    echo "   To install ROS 2, visit: https://docs.ros.org/en/jazzy/Installation.html"
fi
