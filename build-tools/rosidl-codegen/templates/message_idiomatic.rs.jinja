                idiomatic.{{ field.name }}.iter().map(|item| crate::rosidl_runtime_rs::String::from(item.as_str())).collect::<Vec<_>>()
            ),
            {% else if field.is_sequence %}
            // Vec → Sequence conversion with element conversion for nested messages
