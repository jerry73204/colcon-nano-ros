use std::env;
use std::fs;
use std::path::PathBuf;

const PLAN_PATH: &str = "{{ plan_path }}";
const GENERATED_TABLES: &str = concat!(
    "// Generated from: ",
    PLAN_PATH,
    "\n",
    {{ generated_tables_literal }}
);

fn main() {
    println!("cargo:rerun-if-changed={PLAN_PATH}");
    let out_dir = PathBuf::from(env::var_os("OUT_DIR").expect("OUT_DIR is set"));
    let _plan_text = fs::read_to_string(PLAN_PATH).expect("read nros-plan.json");
    fs::write(out_dir.join("nros_generated.rs"), GENERATED_TABLES)
        .expect("write generated Rust tables");
}
